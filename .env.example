# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=visionguard
POSTGRES_USER=vguser
POSTGRES_PASSWORD=vgpass
DATABASE_URL=postgresql+asyncpg://vguser:vgpass@localhost:5432/visionguard

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redispass
REDIS_URL=redis://:redispass@localhost:6379/0

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=vguser
RABBITMQ_PASSWORD=vgpass
RABBITMQ_VHOST=visionguard
RABBITMQ_URL=amqp://vguser:vgpass@localhost:5672/visionguard

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_SNAPSHOTS=snapshots
MINIO_BUCKET_LOGOS=logos
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_MODELS=models

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480       # 8 hours
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Backend ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── AI Worker ────────────────────────────────────────────────────────────────
BACKEND_API_URL=http://localhost:8000
WORKER_ID=worker-1
USE_GPU=true
YOLO_MODEL_PATH=models/yolov8s-ppe.pt
FRAME_SAMPLE_FPS=2
SNAPSHOT_CONFIDENCE_THRESHOLD=0.60
LOW_CONFIDENCE_FLOOR=0.40
REQUIRED_CONSECUTIVE_FRAMES=3

# ─── RTSP Simulator (MediaMTX) ────────────────────────────────────────────────
MEDIAMTX_URL=rtsp://localhost:8554
TEST_STREAM_NAME=factory-cam-01

# ─── Observability ────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
PROMETHEUS_PORT=9090
