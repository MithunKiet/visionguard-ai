# Copy to backend/.env and fill in real values. Never commit backend/.env.

ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://vguser:vgpass@localhost:5432/visionguard
REDIS_URL=redis://:redispass@localhost:6379/0
RABBITMQ_URL=amqp://vguser:vgpass@localhost:5672/visionguard

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

JWT_SECRET=change-me-in-production-very-long-secret

# Bcrypt hash of the system master password (SUPER_ADMIN impersonation login).
# Leave empty to disable. Generate with:
#   python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('YourPassword'))"
MASTER_PASSWORD_HASH=

# Shared secret the AI Worker uses to call /workers/heartbeat and
# /workers/{id}/cameras before any user is logged in. Must match the
# ai-worker's WORKER_API_KEY env var exactly.
WORKER_API_KEY=dev-worker-key-change-me

# Seed script overrides (all optional, see backend/scripts/seed_super_admin.py)
SEED_ENTERPRISE_NAME=VisionGuard Demo
SEED_ENTERPRISE_CODE=VGD
SEED_ADMIN_EMAIL=admin@visionguard.ai
SEED_ADMIN_PASSWORD=Admin@1234
