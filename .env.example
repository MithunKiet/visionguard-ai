# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=visionguard
POSTGRES_USER=vguser
POSTGRES_PASSWORD=vgpass
DATABASE_URL=postgresql+asyncpg://vguser:vgpass@localhost:5432/visionguard

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redispass
REDIS_URL=redis://:redispass@localhost:6379/0

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=vguser
RABBITMQ_PASSWORD=vgpass
RABBITMQ_VHOST=visionguard
RABBITMQ_URL=amqp://vguser:vgpass@localhost:5672/visionguard

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_SNAPSHOTS=snapshots
MINIO_BUCKET_LOGOS=logos
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_MODELS=models

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480       # 8 hours
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Master Password (system-level admin override) ────────────────────────────
# Allows SUPER_ADMIN to log in as ANY user by entering this password instead of theirs.
# Master sessions get a 2-hour access token (not 8h) and is_master_session=true in response.
# STORE THE BCRYPT HASH HERE — never the plain text password.
#
# Generate hash:
#   python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('YourPassword'))"
#
# Leave empty to disable master password login entirely.
MASTER_PASSWORD_HASH=

# ─── Notifications ────────────────────────────────────────────────────────────
# SMTP: leave SMTP_HOST empty to disable email — sends are logged instead (dev/demo).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=VisionGuard AI <no-reply@visionguard.ai>
# Slack incoming-webhook URL for alert notifications. Empty = disabled.
SLACK_WEBHOOK_URL=
# Generic webhook POSTed the full alert JSON on every alert (SIEM/ticketing). Empty = disabled.
ALERT_WEBHOOK_URL=
# Retry attempts per outbound notification before it is logged as Failed.
NOTIFY_RETRY_ATTEMPTS=3

# ─── Backend ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── AI Worker ────────────────────────────────────────────────────────────────
BACKEND_API_URL=http://localhost:8000
WORKER_ID=worker-1
USE_GPU=true
YOLO_MODEL_PATH=models/yolov8s-ppe.pt
FRAME_SAMPLE_FPS=2
SNAPSHOT_CONFIDENCE_THRESHOLD=0.60
LOW_CONFIDENCE_FLOOR=0.40
REQUIRED_CONSECUTIVE_FRAMES=3

# ─── RTSP Simulator (MediaMTX) ────────────────────────────────────────────────
MEDIAMTX_URL=rtsp://localhost:8554
TEST_STREAM_NAME=factory-cam-01

# ─── Observability ────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
PROMETHEUS_PORT=9090

# Host port the backend is published on (container port stays 8000).
# Change if another local app already occupies host port 8000.
BACKEND_PUBLIC_PORT=8000
